# Data — keep placeholders, ignore content
data/*
!data/.gitkeep

# Submissions — keep placeholder, ignore everything except final submission CSVs
submissions/*
!submissions/.gitkeep
!submissions/submission_*.csv

# Common data formats
*.csv
*.zip
*.parquet
*.feather
*.h5

# Exception: final Kaggle submission CSVs are committed for easy download
!submissions/submission_*.csv
!legacy/submissions/submission_*.csv

# Python
__pycache__/
*.py[cod]
*.egg-info/
.env
.venv/
venv/

# Kaggle credentials
.kaggle/

# Claude Code local settings (may contain secrets like API keys)
.claude/settings.local.json

# Jupyter
.ipynb_checkpoints/

# Testing
.pytest_cache/

# Local exploration (not committed)
explore.py
scratch.py

# Model artifacts — INVERTED POLICY (2026-04-27 d8f9c3 onwards):
# Track oof_*.npy, test_*.npy, *_results.json, *.json by default.
# Ignore only regenerable per-fold checkpoints + transient patterns.
# This eliminates the 536-line per-file whitelist that previously
# required a `!scripts/artifacts/oof_X.npy` entry for every new
# candidate. Cross-branch artifact sharing is now the default.
#
# To exclude a specific .npy from tracking, name it with one of the
# transient prefixes (smoke_/tmp_/scratch_) or add an explicit pattern.
scripts/artifacts/*.log
scripts/artifacts/*.db
scripts/artifacts/*.pkl
scripts/artifacts/*_fold[0-9].npy
scripts/artifacts/*_fold[0-9][0-9].npy
scripts/artifacts/*_smoke.npy
scripts/artifacts/_smoke_*.npy
scripts/artifacts/*_tmp.npy
scripts/artifacts/_tmp_*.npy
scripts/artifacts/tmp_*.npy
scripts/artifacts/scratch_*.npy

# CatBoost training logs (auto-generated scratch)
catboost_info/

# Training logs
logs/

# Kaggle kernel outputs + staged dataset contents: big npy duplicates
# of scripts/artifacts/ — skip
kaggle_kernel/output_*/oof_*.npy
kaggle_kernel/output_*/test_*.npy

# Transient downloaded public-kernel notebooks for B1 kernel audit.
# Regenerated ad-hoc via `kaggle kernels pull`. Not worth committing.
kaggle_pulls/

# Per-inner-fold checkpoints for the rehydrate-resilient leakfree teacher.
# Regenerable + auto-cleaned when each outer fold consolidates.
scripts/artifacts/_lf_inner_*.npy

# Kaggle kernel build outputs (assembled dist/ files via build.py).
# Regenerated locally before each push; not source of truth.
kaggle_kernel/kernel_*/dist/

# Kaggle kernel pulled outputs (regenerable via `kaggle kernels output`)
kaggle_kernel/kernel_*/output/
# Kaggle dataset npy payloads (uploaded once, regenerable)
kaggle_kernel/ds_*/test_*.npy
kaggle_kernel/ds_*/oof_*.npy
kernel_audit*/
