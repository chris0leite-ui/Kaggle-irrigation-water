# Data — keep placeholders, ignore content
data/*
!data/.gitkeep

# Submissions — keep placeholder, ignore everything except final submission CSVs
submissions/*
!submissions/.gitkeep
!submissions/submission_*.csv

# Common data formats
*.csv
*.zip
*.parquet
*.feather
*.h5

# Exception: final Kaggle submission CSVs are committed for easy download
!submissions/submission_*.csv
!legacy/submissions/submission_*.csv

# Python
__pycache__/
*.py[cod]
*.egg-info/
.env
.venv/
venv/

# Kaggle credentials
.kaggle/

# Claude Code local settings (may contain secrets like API keys)
.claude/settings.local.json

# Jupyter
.ipynb_checkpoints/

# Testing
.pytest_cache/

# Local exploration (not committed)
explore.py
scratch.py

# Model artifacts — keep summary JSONs, skip bulky OOF/test prob arrays and logs
scripts/artifacts/*.npy
scripts/artifacts/*.log
scripts/artifacts/*.db
scripts/artifacts/*.pkl

# CatBoost training logs (auto-generated scratch)
catboost_info/

# Training logs
logs/

# Kaggle kernel outputs + staged dataset contents: big npy duplicates
# of scripts/artifacts/ — skip
kaggle_kernel/output_*/oof_*.npy
kaggle_kernel/output_*/test_*.npy
kaggle_kernel/ds_*/oof_*.npy
kaggle_kernel/ds_*/test_*.npy

# Exception: commit every OOF + test prob array so any branch/session
# can load them for blending, diagnostics, meta-stacking without
# re-running the training pipeline. Previously a manual allowlist;
# switched to wildcards 2026-04-23 after the allowlist drifted out
# of sync with actual production artefacts across parallel sessions.
# Total size ~368 MB across ~38 files; largest single file ~15 MB
# (within GitHub's 100 MB per-file limit).
!scripts/artifacts/oof_*.npy
!scripts/artifacts/test_*.npy
