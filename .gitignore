!scripts/artifacts/test_tabpfn.npy
# Session B (multi-seed fold bagging): keep per-seed LB-best OOF/test so
# any branch can reproduce the bag without re-running the 8-min pipeline.
!scripts/artifacts/oof_lb_best_fs7.npy
!scripts/artifacts/test_lb_best_fs7.npy
!scripts/artifacts/oof_lb_best_fs123.npy
!scripts/artifacts/test_lb_best_fs123.npy
# Digit-extraction features (NEW LB BEST 0.97468 via digit-XGB, from
# claude/ensemble-model-pipelines-cvHRz)
!scripts/artifacts/oof_xgb_dist_digits.npy
!scripts/artifacts/test_xgb_dist_digits.npy
!scripts/artifacts/oof_lgbm_dist_digits.npy
!scripts/artifacts/test_lgbm_dist_digits.npy
# OTE (ordered target encoding) on digit-enriched feature set — null on
# top of digit-XGB (α=0 peak), but kept for cross-branch diagnostic reuse.
!scripts/artifacts/oof_xgb_dist_digits_ote.npy
!scripts/artifacts/test_xgb_dist_digits_ote.npy
# ExtraTrees variants on dist+digits (v1 class_weight=balanced, v2 none):
# both null vs XGB but saved for greedy-selection experiments
!scripts/artifacts/oof_extratrees_dist_digits.npy
!scripts/artifacts/test_extratrees_dist_digits.npy
!scripts/artifacts/oof_extratrees_dist_digits_v2.npy
!scripts/artifacts/test_extratrees_dist_digits_v2.npy
# Full public-notebook recipe: cat-pair combos + digits + num-as-cat +
# FREQ + ORIG mean/std + LR-formula logits + OrderedTE on ~140 cats,
# heavy-reg XGB. OOF 0.97967 / LB pending. New top candidate.
!scripts/artifacts/oof_recipe_full_te.npy
!scripts/artifacts/test_recipe_full_te.npy
# CatBoost on recipe feature set: CPU (Bernoulli bootstrap, 2000 iter,
# OOF 0.97936 / LB 0.97935) and GPU (Bayesian bootstrap, 16000 iter,
# converged at ~8600 avg, OOF 0.97894 — worse). GPU is null but kept
# for cross-branch diagnostic reuse.
!scripts/artifacts/oof_recipe_full_te_catboost.npy
!scripts/artifacts/test_recipe_full_te_catboost.npy
!scripts/artifacts/oof_catboost_recipe_gpu.npy
!scripts/artifacts/test_catboost_recipe_gpu.npy
