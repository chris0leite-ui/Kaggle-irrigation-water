# Data — keep placeholders, ignore content
data/*
!data/.gitkeep

# Submissions — keep placeholder, ignore everything except final submission CSVs
submissions/*
!submissions/.gitkeep
!submissions/submission_*.csv

# Common data formats
*.csv
*.zip
*.parquet
*.feather
*.h5

# Exception: final Kaggle submission CSVs are committed for easy download
!submissions/submission_*.csv
!legacy/submissions/submission_*.csv

# Python
__pycache__/
*.py[cod]
*.egg-info/
.env
.venv/
venv/

# Kaggle credentials
.kaggle/

# Claude Code local settings (may contain secrets like API keys)
.claude/settings.local.json

# Jupyter
.ipynb_checkpoints/

# Testing
.pytest_cache/

# Local exploration (not committed)
explore.py
scratch.py

# Model artifacts — keep summary JSONs, skip bulky OOF/test prob arrays and logs
scripts/artifacts/*.npy
scripts/artifacts/*.log
scripts/artifacts/*.db

# CatBoost training logs (auto-generated scratch)
catboost_info/

# Training logs
logs/

# Exception: commit these OOF/test artifacts for cross-branch blending.
# Each file is ~6-15 MB; total ~84 MB. Add more with care — check
# OOFS.md for what's tracked and what's not.
!scripts/artifacts/oof_hybrid_lgbmxgb_blend.npy
!scripts/artifacts/test_hybrid_lgbmxgb_blend.npy
!scripts/artifacts/oof_xgb_dist_routed_v3.npy
!scripts/artifacts/test_xgb_dist_routed_v3.npy
!scripts/artifacts/oof_xgb_spec_678.npy
!scripts/artifacts/test_xgb_spec_678.npy
!scripts/artifacts/oof_xgb_vanilla_dist.npy
!scripts/artifacts/test_xgb_vanilla_dist.npy
!scripts/artifacts/oof_lgbm_te_orig.npy
!scripts/artifacts/test_lgbm_te_orig.npy
!scripts/artifacts/oof_xgb_bin_high.npy
!scripts/artifacts/test_xgb_bin_high.npy
!scripts/artifacts/oof_hybrid_binhigh.npy
!scripts/artifacts/test_hybrid_binhigh.npy
