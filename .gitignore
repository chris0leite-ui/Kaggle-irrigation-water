# Competition data — fetched fresh by bootstrap.sh
data/*
!data/.gitkeep

# Cached OOF/test arrays — regenerated on every full run
scripts/artifacts/*
!scripts/artifacts/.gitkeep

# Per-run log directory used by background pipelines
run_logs/

# Submissions — keep only the LB-confirmed reference CSVs
submissions/*
!submissions/.gitkeep
!submissions/submission_recipe_full_te.csv
!submissions/submission_recipe_pseudolabel.csv
!submissions/submission_recipe_greedy_recipe_pseudolabel.csv
!submissions/submission_recipe_pseudolabel_blend.csv
!submissions/submission_recipe_pseudolabel_stage2.csv

# Python
__pycache__/
*.py[cod]
.env
.venv/
